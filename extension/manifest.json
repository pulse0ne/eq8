{
  "manifest_version": 2,
  "name": "eq8",
  "version": "2.0.0",
  "author": "Tyler Snedigar <snedigart@gmail.com>",
  "homepage_url": "https://github.com/pulse0ne/eq8",
  "description": "In-browser parametric equalization",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "scripts": ["background/eq8.iife.js"]
  },
  "browser_action": {
    "default_icon": "icons/icon-48.png",
    "default_title": "eq8",
    "default_popup": "popup/index.html",
    "browser_style": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script/eq8.iife.js"]
    }
  ]
}
